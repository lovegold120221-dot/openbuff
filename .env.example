# Freebuff auth token (from ~/.config/manicode/credentials.json)
FREEBUFF_TOKEN=your-token-here

# Local API key (optional, leave empty for open access)
FREEBUFF_API_KEY=

# Freebuff API base URL
FREEBUFF_API_BASE_URL=https://www.codebuff.com

# Ad providers (try gravity first for lower latency)
FREEBUFF_AD_PROVIDERS=gravity,zeroclick

# Proxy settings
FREEBUFF_PROXY_ENABLED=false
FREEBUFF_PROXY_URL=

# Debug
FREEBUFF_DEBUG=false
FREEBUFF_LOG_LEVEL=INFO
FREEBUFF_LOG_BODY_CHARS=2000
FREEBUFF_LOG_COLOR=true

# Server
FREEBUFF_HOST=127.0.0.1
FREEBUFF_PORT=8000

# Timeout
FREEBUFF_TIMEOUT=60

# Client fingerprint
FREEBUFF_TIMEZONE=UTC
FREEBUFF_LOCALE=en-US
FREEBUFF_OS=linux
